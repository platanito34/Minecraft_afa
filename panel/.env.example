# ============================================================
# MINECRAFT PANEL - Variables de entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# ── Base de datos ────────────────────────────────────────────
DB_HOST=172.18.0.1
DB_PORT=3306
DB_NAME=s16_escolar
DB_USER=panel_user
DB_PASSWORD=cambiar_password_seguro

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=cambiar_por_secreto_muy_largo_y_aleatorio_min_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── Backend ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# ── Frontend (Vite build args) ────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# ── Pterodactyl ──────────────────────────────────────────────
PTERODACTYL_URL=https://tu-panel-pterodactyl.com
PTERODACTYL_API_KEY=ptla_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PTERODACTYL_CLIENT_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password
EMAIL_FROM="Panel Minecraft Escolar <no-reply@tudominio.com>"

# ── RCON (por defecto; se puede sobreescribir por servidor) ──
RCON_DEFAULT_PORT=25575
RCON_DEFAULT_PASSWORD=cambiar_password_rcon
RCON_TIMEOUT=5000

# ── Scheduler ────────────────────────────────────────────────
# Cron expresion para verificar tiempos de juego (cada minuto)
PLAYTIME_CHECK_CRON=* * * * *
# Cron para notificaciones diarias de resumen (a las 21:00)
DAILY_REPORT_CRON=0 21 * * *

# ── Seguridad ────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Admin inicial (solo para primer arranque) ────────────────
INITIAL_ADMIN_EMAIL=admin@escuela.com
INITIAL_ADMIN_PASSWORD=Admin1234!
INITIAL_ADMIN_NAME=Administrador
